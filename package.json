{
  "name": "node-soxr",
  "version": "0.1.3",
  "author": "Clio Orgyán",
  "license": "LGPL-2.1-only",
  "description": "Node native addon wrapper for the SoxR C library.",
  "main": "node-soxr.js",
  "keywords": [
    "soxr",
    "sox",
    "audio",
    "resampling",
    "resampler",
    "resample",
    "node"
  ],
  "files": [
    "soxr",
    "src",
    "prebuilds",
    "node-soxr.d.ts",
    "node-soxr.js",
    "COPYING.LGPL",
    "LICENCE",
    "README.md",
    "binding.gyp",
    "package.json"
  ],
  "engines": {
    "node": ">= 24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tucsok007/node-soxr.git"
  },
  "bugs": {
    "url": "https://github.com/tucsok007/node-soxr/issues"
  },
  "scripts": {
    "install": "node-gyp-build",
    "install-ci": "npm ci --ignore-scripts",
    "configure": "node-gyp configure",
    "build": "./build.sh",
    "gyp:build": "node-gyp confiugure build",
    "gyp:refresh-deps": "rm -rf build node_modules && npm i"
  },
  "gypfile": true,
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "node-web-audio-api": "^1.0.7",
    "prebuildify": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "binary": {
    "module_name": "node-soxr"
  }
}
