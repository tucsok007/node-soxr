{
  "name": "node-soxr",
  "version": "0.1.3",
  "main": "dist/node-soxr.js",
  "files": [
    "dist/",
    "build/",
    "soxr/AUTHORS",
    "soxr/COPYING.LGPL",
    "soxr/LICENCE",
    "COPYING.LGPL",
    "LICENCE",
    "README.md"
  ],
  "scripts": {
    "install": "node-pre-gyp install --fallback-to-build",
    "configure": "node-gyp configure",
    "build": "./build.sh",
    "gyp:build": "node-gyp confiugure build",
    "gyp:refresh-deps": "rm -rf build node_modules && npm i"
  },
  "gypfile": true,
  "author": "Clio Orgyán",
  "license": "LGPL-2.1-only",
  "description": "Node native addon wrapper for the SoxR C library.",
  "dependencies": {
    "@mapbox/node-pre-gyp": "^2.0.3",
    "node-addon-api": "^8.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "node-web-audio-api": "^1.0.7",
    "typescript": "^5.9.3"
  },
  "binary": {
    "module_name": "node-soxr",
    "module_path": "./lib/binding/{configuration}/{node_abi}-{platform}-{arch}-{libc}/",
    "remote_path": "./{module_name}/v{version}/{configuration}/",
    "package_name": "{module_name}-v{version}-{node_abi}-{platform}-{arch}-{libc}.tar.gz",
    "host": "https://registry.unravel.hu"
  }
}
